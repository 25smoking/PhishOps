###############################################################################
# Gophish 云部署配置
# Configuration for Gophish Cloud Deployment
###############################################################################

# ==============================
# 腾讯云配置 (Tencent Cloud) - 主要支持 / Primary Support
# ==============================
# 获取方式 / How to get: https://console.cloud.tencent.com/cam/capi
TENCENT_CLOUD_SECRET_ID=your_secret_id_here
TENCENT_CLOUD_SECRET_KEY=your_secret_key_here

# 可选：指定可用区 (Optional: Specify availability zone)
# 如果部署时提示资源不足，可以尝试指定其他可用区
# If deployment fails due to resource shortage, try specifying another zone
# TENCENT_CLOUD_AVAILABILITY_ZONE=ap-hongkong-3

# ==============================
# SSH 密钥路径 (SSH Key Path) - 可选 / Optional
# ==============================
# 默认使用 ~/.ssh/id_rsa
# Default: ~/.ssh/id_rsa
# 如果你的 SSH 密钥在其他位置，请修改此路径
# If your SSH key is in a different location, modify this path
# SSH_KEY_PATH=$HOME/.ssh/id_rsa

# ==============================
# Git 仓库配置 (Git Repository) - 可选 / Optional
# ==============================
# 如果你 fork 了 GophishModified 并想使用自己的仓库
# If you forked GophishModified and want to use your own repo
# GIT_REPO=https://github.com/your_username/GophisModified.git
# GIT_BRANCH=master

# ==============================
# 实验性支持 - Experimental Support
# ==============================
# 以下云平台配置已准备但未完整测试，使用需自行验证
# The following cloud provider configs are prepared but not fully tested

# 阿里云 (Alibaba Cloud)
# 获取方式: https://ram.console.aliyun.com/manage/ak
# ALIBABA_CLOUD_ACCESS_KEY_ID=your_alibaba_access_key_id
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_alibaba_access_key_secret

# 华为云 (Huawei Cloud)
# 获取方式: https://console.huaweicloud.com/iam/#/mine/accessKey
# HUAWEI_CLOUD_ACCESS_KEY=your_huawei_access_key
# HUAWEI_CLOUD_SECRET_KEY=your_huawei_secret_key

# ==============================
# 快速开始 / Quick Start
# ==============================
# 1. 填写上方的腾讯云密钥 / Fill in Tencent Cloud credentials above
# 2. 确保 SSH 密钥存在 / Ensure SSH key exists: ~/.ssh/id_rsa.pub
# 3. 运行部署脚本 / Run deployment script:
#    python scripts/deploy.py -p tencent -r ap-hongkong
